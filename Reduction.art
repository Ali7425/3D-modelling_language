// --- 5. Test for switch, +++ incrementing and procedures in one test. ---
!try "
  plugin('init');
  procedure draw_tower {
      box 10.0, 40.0, 10.0;
      translate 0.0, 20.0, 0.0;
  }

  i := 1;
  while i < 4 do {
    call draw_tower;
    
    switch i {
      case 1: translate 50.0, 0.0, 0.0;
      case 2: translate -50.0, 0.0, 0.0;
      case 3: translate 0.0, 0.0, 50.0;
    }
    
    i++;
  }
"